# Bu dosyayı kopyalayıp ".env" adıyla kaydedin, değerleri doldurun.
# .env dosyası .gitignore'a eklidir — repoya gitmez.

# Django
SECRET_KEY=buraya-en-az-50-karakterlik-rastgele-bir-deger-yazin
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=helpdesk_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=guclu-bir-sifre-secin

# Veritabanı bağlantısı (Django settings için)
DB_HOST=127.0.0.1
DB_PORT=5433

# E-posta (Gmail için uygulama şifresi gerekir)
# https://myaccount.google.com/apppasswords adresinden alabilirsiniz
EMAIL_HOST_USER=helpdesk@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx

# RDP varsayılan bilgileri
RDP_USERNAME=rdpuser
RDP_PASSWORD=guclu-bir-rdp-sifresi

# noVNC — sunucunuzun yerel ağ IP'si (Wi-Fi/LAN)
# Windows: ipconfig | Linux: ip a
NOVNC_HOST=192.168.x.x

# Guacamole
GUACD_HOSTNAME=172.19.0.1

# Guacamole web arayüzü giriş bilgileri
GUAC_USERNAME=guacadmin
GUAC_PASSWORD=guclu-bir-guac-sifresi
